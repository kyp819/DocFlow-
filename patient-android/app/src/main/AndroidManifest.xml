<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name="com.clinic.patientapp.PatientApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PatientApp"
        android:usesCleartextTraffic="true">

        <!-- Login Activity (Launcher) -->
        <activity
            android:name="com.clinic.patientapp.ui.auth.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Register Activity -->
        <activity
            android:name="com.clinic.patientapp.ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main Navigation Activity -->
        <activity
            android:name="com.clinic.patientapp.ui.main.MainActivity"
            android:exported="false" />

        <!-- Book Appointment Activity -->
        <activity
            android:name="com.clinic.patientapp.ui.appointments.BookAppointmentActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />

    </application>

</manifest>
